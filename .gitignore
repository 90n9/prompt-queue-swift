# Xcode user data
*.xcodeproj/xcuserdata/
*.xcodeproj/project.xcworkspace/xcuserdata/
*.xcworkspace/xcuserdata/
*.xcworkspace/contents.xcworkspacedata
*.xcuserstate
*.xcuserdatad/

# Build artifacts
build/
dist/
DerivedData/
*.xcarchive
*.app
*.dSYM
*.dSYM.zip
*.ipa

# Swift Package Manager
.build/
.swiftpm/
Package.resolved
*.resolved

# CocoaPods (not used, but guard)
Pods/

# Carthage (not used, but guard)
Carthage/Build/
Carthage/Checkouts/

# Instruments / profiling / coverage
*.trace
*.xccov
*.xcresult
*.gcda
*.gcno
*.profraw

# Signing / secrets — never commit
*.mobileprovision
*.provisionprofile
*.cer
*.p12
*.pem
*.key
ExportOptions.plist

# Logs / crash reports
*.log
*.crash
crashlytics-build.properties

# macOS junk
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*
.Spotlight-V100
.Trashes
.fseventsd

# Editors / IDEs
.idea/
.vscode/
*.swp
*.swo
*~

# Local env / tooling
.env
.env.*
.claude/settings.local.json
.claude/local/
.mcp.json
.playwright-mcp/

# Node (in case scripts pull anything in)
node_modules/

# Sparkle framework — downloaded by build.sh into vendor/Sparkle on first build.
# Pinned to SPARKLE_VERSION in build.sh; reproducible without committing 13MB.
vendor/Sparkle/
vendor/Sparkle-*.tar.xz
